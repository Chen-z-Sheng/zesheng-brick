<view>
    <!-- 语音输入动画 -->
    <image class="recordingView" src="https://res.wx.qq.com/mmspraiweb_node/dist/static/openaiplugin/img/recording.gif" wx:if="{{recording && msg.content == ''}}"></image>

    <!-- 用户发送的图片消息 -->
    <view class="query" wx:if="{{msg.type === 'image' || (msg.data && msg.data.image)}}">
      <view class="user-image-wrap">
        <image
          class="user-image-msg"
          src="{{msg.data.url || msg.url || msg.data.imageUrl}}"
          mode="widthFix"
          bindload="onUserImgLoad"
          binderror="onUserImgError"
          bindtap="onPreviewUserImage"
        ></image>
      </view>
      <view class="queryimageview">
        <image class="queryavatar" src="{{userAvatar}}"></image>
      </view>
    </view>

    <!-- 用户文本消息 -->
    <view class="query" wx:elif="{{msg.content != ''}}">
      <view class="rightView">{{msg.content}}</view>
      <view class="queryimageview">
        <image class="queryavatar" src="{{userAvatar}}"></image>
      </view>
    </view>

    <view style='clear: both;'></view>
</view>
