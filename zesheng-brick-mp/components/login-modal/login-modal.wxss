.modal-container {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.48);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    z-index: 9999;
    animation: fadeIn 0.22s ease;
}

.modal-content {
    width: 100%;
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    border-radius: 28rpx 28rpx 0 0;
    padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
    box-sizing: border-box;
    animation: slideUp 0.22s ease;
}

.modal-grabber {
    width: 72rpx;
    height: 8rpx;
    border-radius: 999rpx;
    background: #d4dbe5;
    margin: 0 auto 20rpx;
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18rpx;
}

.modal-title-wrap {
    flex: 1;
    min-width: 0;
}

.modal-title {
    display: block;
    font-size: 38rpx;
    color: #111827;
    font-weight: 700;
    line-height: 1.3;
}

.modal-desc {
    display: block;
    margin-top: 8rpx;
    font-size: 24rpx;
    color: #6b7280;
    line-height: 1.5;
}

.login-panel {
    background: #ffffff;
    border-radius: 24rpx;
    padding: 24rpx 24rpx;
    box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.08);
    border: 1rpx solid #eef2f7;
    backdrop-filter: blur(6px);
}

.brand-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 20rpx;
}

.login-panel-title {
    font-size: 30rpx;
    color: #0f172a;
    font-weight: 600;
    text-align: center;
}

.login-panel-subtitle {
    margin-top: 12rpx;
    font-size: 24rpx;
    color: #64748b;
    text-align: center;
    line-height: 1.5;
}

.phone-mask-line {
    margin-top: 16rpx;
    text-align: center;
    font-size: 28rpx;
    color: #111827;
    font-weight: 600;
    background: #f8fafc;
    border: 1rpx solid #e2e8f0;
    border-radius: 14rpx;
    padding: 12rpx 16rpx;
}

.carrier-doc-row {
    margin-top: 14rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8rpx 10rpx;
}

.carrier-link {
    font-size: 22rpx;
    color: #2563eb;
}

.carrier-split {
    font-size: 22rpx;
    color: #94a3b8;
}

.agree-block {
    margin-top: 16rpx;
    margin-bottom: 4rpx;
}

.agree-row {
    display: flex;
    align-items: flex-start;
}

.agree-text {
    flex: 1;
    margin-left: 10rpx;
    font-size: 22rpx;
    color: #475569;
    line-height: 1.45;
}

.login-btn {
    width: 100%;
    height: 88rpx;
    border-radius: 44rpx;
    font-size: 30rpx;
    font-weight: 600;
    margin-top: 18rpx;
    padding: 0 24rpx;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1.2;
}

.btn-text {
    display: block;
    line-height: 1.2;
    text-align: center;
}

.login-btn::after {
    border: none;
}

.login-btn-primary {
    color: #ffffff;
    background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
    box-shadow: 0 10rpx 22rpx rgba(34, 197, 94, 0.28);
}

.login-btn-primary:active {
    transform: translateY(2rpx);
    box-shadow: 0 6rpx 14rpx rgba(34, 197, 94, 0.22);
}

.login-btn-secondary {
    color: #2563eb;
    background: #eff6ff;
    border: 1rpx solid #bfdbfe;
}

.login-btn-secondary:active {
    background: #e2ecff;
}

.footer-tip {
    display: block;
    margin-top: 20rpx;
    text-align: center;
    font-size: 22rpx;
    color: #94a3b8;
    line-height: 1.4;
}

.login-btn:active {
    opacity: 0.9;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

@keyframes slideUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
}