.modal-container {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.45);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    z-index: 9999;
    animation: fadeIn 0.2s ease;
}

.modal-sheet {
    width: 100%;
    background: #ffffff;
    border-radius: 24rpx 24rpx 0 0;
    padding: 16rpx 32rpx calc(28rpx + env(safe-area-inset-bottom));
    box-sizing: border-box;
    animation: slideUp 0.24s ease;
}

.modal-grabber {
    width: 64rpx;
    height: 8rpx;
    border-radius: 999rpx;
    background: #e5e7eb;
    margin: 0 auto 20rpx;
}

.modal-head {
    margin-bottom: 28rpx;
}

.modal-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #111827;
    line-height: 1.3;
}

.login-actions {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
}

.phone-hint {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12rpx;
    padding: 12rpx 20rpx;
    background: #f9fafb;
    border-radius: 12rpx;
}

.phone-hint-label {
    font-size: 24rpx;
    color: #6b7280;
}

.phone-hint-value {
    font-size: 26rpx;
    color: #111827;
    font-weight: 600;
}

.action-btn {
    width: 100%;
    height: 80rpx;
    border-radius: 40rpx;
    font-size: 28rpx;
    font-weight: 500;
    margin: 0;
    padding: 0;
    color: #374151;
    background: #f3f4f6;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    box-sizing: border-box;
}

.action-btn::after {
    border: none;
}

.action-btn:active:not([disabled]) {
    background: #e5e7eb;
}

.action-btn[disabled] {
    color: #9ca3af;
    background: #f3f4f6;
}

.agree-footer {
    margin-top: 32rpx;
    display: flex;
    justify-content: center;
    padding: 0 8rpx;
}

.agree-group {
    width: 100%;
    display: flex;
    justify-content: center;
}

.agree-label {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    max-width: 100%;
}

.agree-checkbox-box {
    flex-shrink: 0;
    width: 36rpx;
    height: 32rpx;
    margin-right: 10rpx;
    margin-top: -6rpx;
    display: flex;
    align-items: center;
    justify-content: center;
}

.agree-checkbox {
    transform: scale(0.88);
    transform-origin: center center;
}

.agree-checkbox .wx-checkbox-input {
    width: 30rpx !important;
    height: 30rpx !important;
    border-radius: 50% !important;
}

.agree-checkbox .wx-checkbox-input.wx-checkbox-input-checked {
    background: #07c160 !important;
    border-color: #07c160 !important;
}

.agree-copy {
    flex: 0 1 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    max-width: 560rpx;
    text-align: center;
    row-gap: 2rpx;
}

.agree-plain,
.agree-link {
    font-size: 22rpx;
    line-height: 32rpx;
    color: #6b7280;
}

.agree-link {
    color: #07c160;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

@keyframes slideUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
}
