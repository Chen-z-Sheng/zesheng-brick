<view class="modal-container" wx:if="{{visible}}" bindtap="handleModalClose">
    <view class="modal-sheet" catchtap="catchTap">
        <view class="modal-grabber"></view>

        <view class="modal-head">
            <text class="modal-title">{{title}}</text>
        </view>

        <view class="login-actions">
            <view class="phone-hint" wx:if="{{identityMode === 'donut' && phoneMask}}">
                <text class="phone-hint-label">本机号码</text>
                <text class="phone-hint-value">{{phoneMask}}</text>
            </view>

            <block wx:if="{{identityMode === 'donut'}}">
                <button
                    wx:if="{{!agreePlatform}}"
                    class="action-btn"
                    bindtap="onOneClickBlocked"
                >
                    本机号码一键登录
                </button>
                <button
                    wx:else
                    class="action-btn"
                    open-type="phoneOneClickLogin"
                    bindphoneoneclicklogin="onPhoneOneClick"
                    disabled="{{loading || !nativeOneClickReady}}"
                    loading="{{loading}}"
                >
                    本机号码一键登录
                </button>
            </block>
            <block wx:else>
                <button
                    wx:if="{{!agreePlatform}}"
                    class="action-btn"
                    bindtap="onQuickLoginBlocked"
                >
                    手机号快捷登录
                </button>
                <button
                    wx:else
                    class="action-btn"
                    open-type="getPhoneNumber"
                    bindgetphonenumber="onPhoneQuickLogin"
                    disabled="{{loading}}"
                    loading="{{loading}}"
                >
                    手机号快捷登录
                </button>
            </block>

            <button class="action-btn" bindtap="goSmsLogin" disabled="{{loading}}">
                验证码登录
            </button>
        </view>

        <view class="agree-footer">
            <checkbox-group class="agree-group" bindchange="onAgreePlatformChange">
                <label class="agree-label">
                    <view class="agree-checkbox-box">
                        <checkbox class="agree-checkbox" value="agree" color="#07c160" />
                    </view>
                    <view class="agree-copy">
                        <text class="agree-plain">我已阅读并同意</text>
                        <text class="agree-link" catchtap="openPlatformDoc" data-which="user">《用户服务协议》</text>
                        <text class="agree-plain">和</text>
                        <text class="agree-link" catchtap="openPlatformDoc" data-which="privacy">《隐私政策》</text>
                        <block wx:if="{{identityMode === 'donut'}}">
                            <text class="agree-plain">及</text>
                            <text class="agree-link" catchtap="openCarrierDoc" data-which="cm">运营商条款</text>
                        </block>
                    </view>
                </label>
            </checkbox-group>
        </view>
    </view>
</view>
