.imgcard-img {
  width: 200px;
  max-width: 200px;
  min-height: 80px;
  margin: 10px 0;
  border-radius: 8px;
}
.container {
  display: flex;
  align-items: flex-start;
}
.answerimage {
  width: 38px;
  height: 38px;
  margin-right: 10px;
  margin-top: 10px;
  flex-shrink: 0;
  border-radius: 4px;
}
.img-error {
  margin: 10px 0;
  padding: 20px 24px;
  background: #f5f5f5;
  border-radius: 8px;
  max-width: 200px;
}
.img-error-text {
  font-size: 12px;
  color: #999;
}
