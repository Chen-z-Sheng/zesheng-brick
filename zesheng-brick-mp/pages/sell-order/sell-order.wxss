/* pages/sell-order/sell-order.wxss */
page {
  background: #f7f7f7;
}

.page {
  width: 100%;
  box-sizing: border-box;
  padding-bottom: 180rpx;
  background: #f7f7f7;
}

.page-need-login {
  height: 100vh;
  overflow: hidden;
  padding-bottom: 0;
}

/* 未登录提示 */
.need-login-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.need-login-text {
  font-size: 28rpx;
  color: #bbbbbb;
}

/* 表单容器 */
.form {
  padding: 16rpx 24rpx;
  box-sizing: border-box;
}

/* 单元格组 */
.cell-group {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
}

.cell-group.logistics-group {
  overflow: visible;
  position: relative;
  z-index: 200;
}

.cell-group.logistics-group > .cell.logistics-input-wrap:last-child {
  border-bottom-left-radius: 16rpx;
  border-bottom-right-radius: 16rpx;
}

.cell-group.cell-group-product {
  overflow: visible;
  position: relative;
  z-index: 300;
}

.cell-group-title {
  padding: 20rpx 24rpx 0;
  font-size: 24rpx;
  color: #999999;
  font-weight: 400;
}

.required {
  color: #ef4444;
  margin-left: 4rpx;
}

/* 单元格 */
.cell {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  padding: 0 24rpx;
  background: #ffffff;
}

.cell:not(:last-child) {
  border-bottom: 1rpx solid #f5f5f5;
}

.cell-input {
  width: 100%;
  height: 96rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  background: transparent;
  border: none;
  padding: 0;
}

.input-placeholder {
  color: #bbbbbb;
}

/* 选择器单元格 */
.cell-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  padding: 0 24rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #1a1a1a;
}

.picker-placeholder {
  font-size: 28rpx;
  color: #bbbbbb;
}

.picker-arrow {
  font-size: 28rpx;
  color: #cccccc;
}

/* 多行文本 */
.cell-textarea-wrap {
  align-items: flex-start;
  padding: 16rpx 24rpx 20rpx;
}

.cell-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  line-height: 1.6;
  padding: 0;
  background: transparent;
  border: none;
}

/* ============================================
   商品列表
   ============================================ */
.product-list {
  padding: 0 24rpx;
}

.product-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.product-item:last-child {
  border-bottom: none;
}

.product-item-info {
  flex: 1;
  min-width: 0;
  overflow: visible;
}

.product-item-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.product-input-wrap {
  position: relative;
}

.product-name-input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  background: #f7f7f7;
  border-radius: 10rpx;
  box-sizing: border-box;
  border: 1rpx solid transparent;
  transition: border-color 0.15s;
}

.stepper {
  display: flex;
  align-items: center;
  width: 180rpx;
  height: 56rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  overflow: hidden;
  background: #f7f7f7;
}

.stepper-minus,
.stepper-plus {
  width: 56rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333333;
  background: #ffffff;
  flex-shrink: 0;
}

.stepper-minus {
  border-right: 1rpx solid #e5e5e5;
}

.stepper-plus {
  border-left: 1rpx solid #e5e5e5;
}

.stepper-minus:active,
.stepper-plus:active {
  background: #f5f5f5;
}

.stepper-num {
  flex: 1;
  height: 100%;
  text-align: center;
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
  padding: 0;
  background: transparent;
  border: none;
}

.product-item-del {
  font-size: 22rpx;
  color: #ef4444;
  padding: 8rpx 12rpx;
  background: rgba(239, 68, 68, 0.08);
  border-radius: 8rpx;
  flex-shrink: 0;
}

/* 新增商品按钮 */
.product-add-wrap {
  padding: 12rpx 24rpx 20rpx;
}

.product-add-btn {
  width: 100%;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
  color: #07c160;
  background: rgba(7, 193, 96, 0.06);
  border: 1rpx dashed rgba(7, 193, 96, 0.4);
  border-radius: 10rpx;
  box-sizing: border-box;
  gap: 8rpx;
}

.product-add-btn:active {
  background: rgba(7, 193, 96, 0.1);
}

/* 物流公司下拉 */
.logistics-input-wrap {
  position: relative;
}

.suggest-list {
  position: absolute;
  left: 0;
  right: 0;
  top: calc(100% + 4rpx);
  max-height: 400rpx;
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  z-index: 500;
  border: 1rpx solid #f0f0f0;
  overflow: hidden;
}

.suggest-list-scroll {
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  max-height: 400rpx;
  box-sizing: border-box;
}

.suggest-item {
  padding: 24rpx;
  font-size: 28rpx;
  color: #333333;
  border-bottom: 1rpx solid #f5f5f5;
}

.suggest-item:last-child {
  border-bottom: none;
}

.suggest-item:active {
  background: #f5f5f5;
}

/* 寄件人弹窗 */
.sender-modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  animation: maskIn 0.2s ease;
}

@keyframes maskIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.sender-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 620rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  z-index: 1001;
  animation: popIn 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes popIn {
  from { transform: translate(-50%, -50%) scale(0.85); opacity: 0; }
  to { transform: translate(-50%, -50%) scale(1); opacity: 1; }
}

.sender-modal-title {
  padding: 36rpx 32rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  text-align: center;
}

.sender-modal-subtitle {
  display: block;
  padding: 10rpx 32rpx 0;
  text-align: center;
  font-size: 22rpx;
  color: #999999;
}

.sender-modal-body {
  padding: 28rpx 32rpx 0;
}

.sender-modal-row {
  margin-bottom: 20rpx;
}

.sender-modal-label {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 10rpx;
}

.sender-modal-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  background: #f8fafc;
  border-radius: 14rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.sender-modal-footer {
  display: flex;
  border-top: 1rpx solid #f5f5f5;
  margin-top: 24rpx;
}

.sender-modal-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  transition: background 0.15s;
}

.sender-modal-btn:active {
  background: #f7f7f7;
}

.sender-modal-btn.cancel {
  color: #666666;
  border-right: 1rpx solid #f5f5f5;
}

.sender-modal-btn.confirm {
  color: #07c160;
  font-weight: 600;
}

.sender-list-modal .sender-list-body {
  max-height: 480rpx;
  overflow-y: auto;
  padding: 8rpx 28rpx 0;
}

.sender-list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.sender-list-item:last-child {
  border-bottom: none;
}

.sender-list-item:active {
  background: #f9f9f9;
}

.sender-list-text {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  margin-right: 24rpx;
}

.sender-list-del {
  font-size: 24rpx;
  color: #ef4444;
  padding: 8rpx 16rpx;
  background: rgba(239, 68, 68, 0.08);
  border-radius: 999rpx;
  flex-shrink: 0;
}

/* 底部提交 */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  padding: 16rpx 24rpx calc(16rpx + constant(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.footer-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.footer-btn::after {
  border: none;
}

.footer-submit {
  background: #07c160;
  color: #ffffff;
}

.footer-submit:active {
  background: #06ad56;
}
