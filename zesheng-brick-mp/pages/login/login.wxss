/* pages/login/login.wxss */
page {
  background: #ffffff;
}

.login-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #ffffff;
  padding: 0 40rpx;
  box-sizing: border-box;
}

/* ============================================
   顶部品牌区域
   ============================================ */
.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  padding-bottom: 64rpx;
}

.logo {
  width: 128rpx;
  height: 128rpx;
  margin-bottom: 28rpx;
  border-radius: 28rpx;
  background: rgba(7, 193, 96, 0.08);
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.slogan {
  font-size: 26rpx;
  color: #999999;
  letter-spacing: 1rpx;
}

/* ============================================
   登录内容区
   ============================================ */
.login-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.login-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 8rpx;
  display: block;
}

.login-desc {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  margin-bottom: 48rpx;
  display: block;
}

.login-buttons {
  width: 100%;
}

/* 本机号码显示 */
.mask-line {
  width: 100%;
  font-size: 30rpx;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 20rpx;
  font-weight: 600;
  display: block;
}

/* 运营商协议 */
.carrier-doc-row {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 4rpx 12rpx;
  margin-bottom: 20rpx;
}

.carrier-link {
  font-size: 22rpx;
  color: #07c160;
}

.carrier-split {
  font-size: 22rpx;
  color: #cccccc;
}

/* 同意协议 */
.agree-block {
  width: 100%;
  margin-bottom: 24rpx;
}

.agree-row {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.agree-text {
  flex: 1;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

/* 主要登录按钮 */
.wechat-login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  background: #07c160;
  border-radius: 48rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 28rpx;
  border: none;
  transition: background 0.15s;
}

.wechat-login-btn::after {
  border: none;
}

.wechat-login-btn[disabled] {
  background: #cccccc;
}

.wechat-login-btn:active:not([disabled]) {
  background: #06ad56;
}

.wechat-login-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

/* 分割线 */
.login-divider {
  width: 100%;
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.login-divider-line {
  flex: 1;
  height: 1rpx;
  background: #f0f0f0;
}

.login-divider-text {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #bbbbbb;
  white-space: nowrap;
}

/* 输入框 */
.sms-input {
  width: 100%;
  box-sizing: border-box;
  height: 96rpx;
  padding: 0 28rpx;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  border-radius: 48rpx;
  border: 2rpx solid #e5e5e5;
  background: #f9f9f9;
  color: #1a1a1a;
  transition: border-color 0.15s, background 0.15s;
}

.sms-input-code {
  margin-bottom: 24rpx;
}

/* 发送验证码按钮 */
.sms-send-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #07c160;
  background: #ffffff;
  border-radius: 40rpx;
  border: 2rpx solid #07c160;
}

.sms-send-btn::after {
  border: none;
}

.sms-send-btn[disabled] {
  color: #bbbbbb;
  border-color: #e5e5e5;
}

/* 验证码登录按钮 */
.sms-submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  background: #07c160;
  border-radius: 48rpx;
  border: none;
  margin-bottom: 16rpx;
}

.sms-submit-btn::after {
  border: none;
}

.sms-submit-btn:active {
  background: #06ad56;
}

.legacy-tip {
  display: block;
  width: 100%;
  font-size: 22rpx;
  color: #bbbbbb;
  text-align: center;
  line-height: 1.6;
  margin-top: 20rpx;
}

/* ============================================
   底部协议
   ============================================ */
.login-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 56rpx;
  padding-top: 32rpx;
  flex-wrap: wrap;
  gap: 0;
}

.footer-text {
  font-size: 22rpx;
  color: #bbbbbb;
}

.footer-link {
  font-size: 22rpx;
  color: #07c160;
}
