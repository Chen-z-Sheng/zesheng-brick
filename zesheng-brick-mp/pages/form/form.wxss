/* pages/form/form.wxss */
.form-page {
  min-height: 100vh;
  background: #f7f7f7;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

/* ============================================
   选项卡片
   ============================================ */
.options-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-card {
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.option-card:active {
  transform: scale(0.98);
}

.option-normal {
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
}

.option-market {
  background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
}

/* 背景装饰圆 */
.option-card-bg {
  position: absolute;
  bottom: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 50%;
  pointer-events: none;
}

.option-card-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 40rpx 36rpx;
  gap: 24rpx;
}

.option-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option-icon {
  font-size: 44rpx;
}

.option-text-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.option-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.option-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
}

.option-arrow {
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.option-arrow-icon {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid rgba(255, 255, 255, 0.7);
  border-right: 3rpx solid rgba(255, 255, 255, 0.7);
  transform: rotate(45deg);
}

/* ============================================
   温馨提示卡片
   ============================================ */
.tips-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 28rpx 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tips-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tips-icon {
  font-size: 32rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.tips-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.tips-dot {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 700;
  flex-shrink: 0;
  line-height: 1.6;
}

.tips-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  flex: 1;
}
