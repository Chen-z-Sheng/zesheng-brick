/* pages/feedback/feedback.wxss - 问题反馈页，遵循微信 UI 规范 */
.page {
    min-height: 100vh;
    background: #f7f7f7;
    padding: 24rpx;
    padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
    box-sizing: border-box;
}

/* 页面标题 */
.page-header {
    padding: 8rpx 8rpx 24rpx;
}

.page-title {
    font-size: 36rpx;
    font-weight: 700;
    color: #1a1a1a;
    display: block;
}

/* 表单卡片 */
.form-card {
    background: #ffffff;
    border-radius: 24rpx;
    padding: 8rpx 32rpx 28rpx;
    margin-bottom: 24rpx;
}

.form-item {
    padding: 24rpx 0;
    border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
    border-bottom: none;
}

.form-item-no-border {
    border-bottom: none;
}

.form-item-upload {
    padding-top: 8rpx;
}

.label {
    display: block;
    font-size: 30rpx;
    color: #1a1a1a;
    font-weight: 500;
    margin-bottom: 16rpx;
}

/* 选择器 */
.picker-value {
    height: 88rpx;
    line-height: 88rpx;
    padding: 0 24rpx;
    background: #f7f7f7;
    border-radius: 12rpx;
    color: #1a1a1a;
    font-size: 30rpx;
    position: relative;
}

.picker-value::after {
    content: '▼';
    position: absolute;
    right: 24rpx;
    font-size: 22rpx;
    color: #b0b0b0;
}

/* 文本输入 */
.content-input {
    width: 100%;
    min-height: 240rpx;
    background: #f7f7f7;
    border-radius: 16rpx;
    padding: 24rpx;
    box-sizing: border-box;
    font-size: 30rpx;
    color: #1a1a1a;
    line-height: 1.6;
}

.content-placeholder {
    color: #b0b0b0;
    font-size: 30rpx;
}

.word-count {
    margin-top: 12rpx;
    display: block;
    text-align: right;
    color: #b0b0b0;
    font-size: 24rpx;
}

/* 图片上传 */
.image-list {
    display: flex;
    flex-wrap: wrap;
    gap: 16rpx;
    margin-top: 8rpx;
}

.image-item {
    width: 200rpx;
    height: 200rpx;
    border-radius: 16rpx;
    position: relative;
    overflow: hidden;
    background: #f7f7f7;
}

.preview-image {
    width: 100%;
    height: 100%;
}

.remove-btn {
    position: absolute;
    top: 0;
    right: 0;
    width: 44rpx;
    height: 44rpx;
    line-height: 44rpx;
    text-align: center;
    background: rgba(0, 0, 0, 0.55);
    color: #ffffff;
    font-size: 28rpx;
    border-radius: 0 16rpx 0 16rpx;
}

.remove-btn:active {
    background: rgba(0, 0, 0, 0.7);
}

.image-uploader {
    width: 200rpx;
    height: 200rpx;
    border: 2rpx dashed #d0d0d0;
    border-radius: 16rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #fafafa;
    transition: all 0.2s ease;
}

.image-uploader:active {
    border-color: #07c160;
    background: rgba(7, 193, 96, 0.04);
}

.plus-icon {
    font-size: 52rpx;
    color: #b0b0b0;
    line-height: 1;
    margin-bottom: 4rpx;
}

.plus-text {
    font-size: 22rpx;
    color: #b0b0b0;
}

/* 按钮区 */
.footer {
    margin-top: 12rpx;
    padding: 0 8rpx;
}

.submit-btn {
    width: 100%;
    height: 92rpx;
    font-size: 34rpx;
    font-weight: 500;
    border-radius: 16rpx;
    background: #07c160;
    color: #ffffff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0;
    line-height: 1;
    transition: opacity 0.2s ease;
}

.submit-btn::after {
    border: none;
}

.submit-btn:active {
    opacity: 0.85;
}

.submit-btn[loading] {
    opacity: 0.7;
}

.history-btn {
    width: 100%;
    height: 92rpx;
    font-size: 32rpx;
    border-radius: 16rpx;
    background: #ffffff;
    color: #1a1a1a;
    border: 1rpx solid #e5e5e5;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 32rpx;
    padding: 0;
    line-height: 1;
}

.history-btn::after {
    border: none;
}

.history-btn:active {
    background: #f7f7f7;
}
