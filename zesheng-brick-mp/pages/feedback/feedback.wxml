<view class="page">
    <view class="page-header">
        <text class="page-title">问题反馈</text>
    </view>

    <view class="form-card">
        <!-- 反馈类型 -->
        <view class="form-item">
            <text class="label">反馈类型</text>
            <picker mode="selector" range="{{feedbackTypeOptions}}" value="{{feedbackTypeIndex}}" bindchange="onFeedbackTypeChange">
                <view class="picker-value">{{feedbackTypeOptions[feedbackTypeIndex]}}</view>
            </picker>
        </view>

        <!-- 问题描述 -->
        <view class="form-item form-item-no-border">
            <text class="label">问题描述</text>
            <textarea
                class="content-input"
                placeholder="请描述你遇到的问题或建议，至少 5 个字"
                placeholder-class="content-placeholder"
                maxlength="500"
                value="{{content}}"
                bindinput="onContentInput"
            />
            <text class="word-count">{{content.length}} / 500</text>
        </view>

        <!-- 上传图片 -->
        <view class="form-item form-item-no-border form-item-upload">
            <text class="label">上传图片（选填）</text>
            <view class="image-list">
                <view class="image-item" wx:for="{{imageUrls}}" wx:key="*this">
                    <image class="preview-image" src="{{item}}" mode="aspectFill" bindtap="onPreviewImage" data-url="{{item}}" />
                    <view class="remove-btn" bindtap="onRemoveImage" data-index="{{index}}">×</view>
                </view>
                <view class="image-uploader" wx:if="{{imageUrls.length < 3}}" bindtap="onChooseImage">
                    <text class="plus-icon">+</text>
                    <text class="plus-text">添加图片</text>
                </view>
            </view>
        </view>
    </view>

    <view class="footer">
        <button class="submit-btn" loading="{{submitting}}" bindtap="onSubmit" hover-class="none">提交反馈</button>
        <button class="history-btn" bindtap="onGoHistory" hover-class="none">查看历史反馈</button>
    </view>
</view>
