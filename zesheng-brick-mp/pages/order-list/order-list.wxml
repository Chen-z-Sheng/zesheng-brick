                                    <text class="order-card__logistics-err" wx:elif="{{item.logisticsSummary.errorMessage}}">{{item.logisticsSummary.errorMessage}}</text>
                                </view>
                            </block>
                            <block wx:else>
                                <view class="order-card__row"><text class="order-card__label">商品明细</text><text class="order-card__value order-card__value--multi">{{item.productDetail}}</text></view>
                                <view class="order-card__row"><text class="order-card__label">快递单号</text><text class="order-card__value">{{item.logisticsNo || '—'}}</text></view>
                                <view class="order-card__row"><text class="order-card__label">是否寄存</text><text class="order-card__value">{{item.depositText}}</text></view>
