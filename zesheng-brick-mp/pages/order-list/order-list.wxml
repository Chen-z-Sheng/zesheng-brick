                    <text class="empty__title">运输中暂无订单</text>
                </view>
                <view class="loading-wrap" wx:if="{{loading && listTransit.length === 0}}">
                    <text class="loading-wrap__text">加载中...</text>
                </view>
                <view class="nomore" wx:if="{{!hasMore_transit && listTransit.length > 0 && !loading}}">
                    <text class="nomore__text">— 已加载全部 —</text>
                </view>
            </scroll-view>
