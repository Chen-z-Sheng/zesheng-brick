/* pages/order-list/order-list.wxss */
page {
    background: #f7f7f7;
}

.page {
    height: 100vh;
    background: #f7f7f7;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-sizing: border-box;
}

/* ============================================
   Tab 标签栏
   ============================================ */
.tabs-wrap {
    flex-shrink: 0;
    background: #ffffff;
    border-bottom: 1rpx solid #f0f0f0;
}

.tabs-scroll {
    width: 100%;
}

.tabs-inner {
    display: inline-flex;
    align-items: center;
    padding: 12rpx 20rpx 0;
    gap: 0;
    min-height: 80rpx;
}

.tab {
    flex-shrink: 0;
    padding: 0 28rpx;
    height: 68rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border-bottom: 4rpx solid transparent;
    box-sizing: border-box;
    margin-bottom: -1rpx;
}

.tab__text {
    font-size: 28rpx;
    color: #999999;
    font-weight: 400;
}

.tab--on .tab__text {
    color: #07c160;
    font-weight: 600;
}

/* 激活下划线 */
.tab--on::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 40rpx;
    height: 4rpx;
    background: #07c160;
    border-radius: 2rpx;
}

/* ============================================
   内容区
   ============================================ */
.swiper {
    flex: 1;
    height: 0;
}

.panel {
    height: 100%;
    background: #f7f7f7;
    box-sizing: border-box;
}

.list {
    padding: 20rpx 24rpx 60rpx;
}

/* ============================================
   订单卡片
   ============================================ */
.order-card {
    background: #ffffff;
    border-radius: 16rpx;
    margin-bottom: 16rpx;
    overflow: hidden;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
    transition: transform 0.15s;
}

.order-card:active {
    transform: scale(0.99);
}

.order-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20rpx 24rpx 18rpx;
    border-bottom: 1rpx solid #f5f5f5;
}

.order-card__head--no-status {
    justify-content: flex-start;
}

.order-card__type {
    font-size: 22rpx;
    padding: 8rpx 18rpx;
    border-radius: 24rpx;
    font-weight: 500;
}

.order-card__type--form {
    background: rgba(7, 193, 96, 0.1);
    color: #07c160;
}

.order-card__type--sell {
    background: rgba(59, 130, 246, 0.1);
    color: #3b82f6;
}

.order-card__status {
    font-size: 24rpx;
    font-weight: 600;
    color: #07c160;
}

.order-card__body {
    padding: 20rpx 24rpx 24rpx;
    box-sizing: border-box;
}

.order-card__row {
    display: flex;
    align-items: flex-start;
    margin-bottom: 12rpx;
    font-size: 26rpx;
}

.order-card__row:last-child {
    margin-bottom: 0;
}

.order-card__label {
    flex-shrink: 0;
    width: 144rpx;
    color: #999999;
    line-height: 1.5;
}

.order-card__value {
    flex: 1;
    color: #333333;
    word-break: break-all;
    line-height: 1.5;
}

.order-card__value--multi {
    white-space: pre-wrap;
}

/* 物流信息 */
.order-card__logistics {
    margin-top: 14rpx;
    padding: 16rpx 18rpx;
    background: #f7fff9;
    border-radius: 10rpx;
    border-left: 4rpx solid #07c160;
    box-sizing: border-box;
}

.order-card__logistics-label {
    display: block;
    font-size: 20rpx;
    font-weight: 600;
    color: #07c160;
    margin-bottom: 8rpx;
    letter-spacing: 1rpx;
}

.order-card__one-line {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    font-size: 24rpx;
    color: #444444;
    line-height: 1.5;
    word-break: break-all;
}

.order-card__logistics-err {
    display: block;
    font-size: 24rpx;
    color: #ef4444;
    line-height: 1.4;
}

/* 管理员备注 */
.order-card__admin-note {
    margin-top: 14rpx;
    padding: 14rpx 18rpx;
    background: #fffbeb;
    border-left: 4rpx solid #f59e0b;
    border-radius: 10rpx;
}

.order-card__admin-note-label {
    display: block;
    font-size: 20rpx;
    font-weight: 600;
    color: #d97706;
    margin-bottom: 6rpx;
    letter-spacing: 1rpx;
}

.order-card__admin-note-value {
    display: block;
    font-size: 24rpx;
    color: #333333;
    line-height: 1.5;
    word-break: break-all;
}

/* ============================================
   空状态
   ============================================ */
.empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 120rpx 32rpx 60rpx;
}

.empty__icon {
    display: block;
    font-size: 88rpx;
    margin-bottom: 24rpx;
    opacity: 0.45;
}

.empty__title {
    display: block;
    font-size: 30rpx;
    color: #999999;
    font-weight: 500;
    margin-bottom: 12rpx;
}

.empty__hint {
    display: block;
    font-size: 24rpx;
    color: #bbbbbb;
    text-align: center;
    line-height: 1.6;
}

/* 加载 */
.loading-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60rpx;
}

.loading-wrap__text {
    font-size: 26rpx;
    color: #bbbbbb;
}

/* 底部无更多 */
.nomore {
    padding: 28rpx;
    text-align: center;
}

.nomore__text {
    font-size: 22rpx;
    color: #cccccc;
}
