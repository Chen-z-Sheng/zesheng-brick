/* pages/payment-info/payment-info.wxss - 打款信息页，遵循微信 UI 规范 */
.container {
    padding: 24rpx;
    background-color: #f7f7f7;
    min-height: 100vh;
    padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
    box-sizing: border-box;
}

/* 页面标题 */
.page-header {
    padding: 8rpx 8rpx 28rpx;
}

.page-title {
    font-size: 36rpx;
    font-weight: 700;
    color: #1a1a1a;
    display: block;
}

.page-subtitle {
    font-size: 26rpx;
    color: #999999;
    margin-top: 8rpx;
    display: block;
}

/* 表单卡片 */
.form-card {
    background: #ffffff;
    border-radius: 24rpx;
    padding: 8rpx 32rpx;
    margin-bottom: 24rpx;
}

/* 表单项 */
.form-item {
    padding: 28rpx 0;
    border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
    border-bottom: none;
}

.form-item-uploader {
    border-bottom: none;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
}

.form-item-uploader {
    border-bottom: none;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
}

.form-label {
    font-size: 30rpx;
    color: #1a1a1a;
    font-weight: 500;
    margin-bottom: 16rpx;
    display: flex;
    align-items: center;
}

.required {
    color: #fa5151;
    margin-left: 6rpx;
    font-size: 28rpx;
}

/* 输入框 */
.form-input {
    width: 100%;
    height: 88rpx;
    font-size: 32rpx;
    color: #1a1a1a;
    border-bottom: 2rpx solid #e5e5e5;
    transition: border-color 0.2s ease;
    box-sizing: border-box;
    padding: 0 4rpx;
}

.form-input-placeholder {
    color: #b0b0b0;
    font-size: 32rpx;
}

.form-input:focus {
    border-bottom-color: #07c160;
}

/* 上传区域 */
.upload-section {
    margin-top: 16rpx;
}

.upload-area {
    width: 240rpx;
    height: 240rpx;
    border: 2rpx dashed #d0d0d0;
    border-radius: 16rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #fafafa;
    transition: all 0.2s ease;
    margin: 0 auto;
}

.upload-area:active {
    border-color: #07c160;
    background: rgba(7, 193, 96, 0.04);
}

.upload-icon {
    font-size: 56rpx;
    color: #b0b0b0;
    line-height: 1;
    margin-bottom: 8rpx;
}

.upload-text {
    font-size: 24rpx;
    color: #b0b0b0;
}

/* 预览区域 */
.preview-area {
    width: 240rpx;
    margin: 0 auto;
    border-radius: 16rpx;
    overflow: hidden;
    background: #fafafa;
    position: relative;
}

.preview-image-wrap {
    width: 240rpx;
    height: 240rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fafafa;
}

.preview-image {
    width: 100%;
    height: 100%;
}

.preview-mask {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
}

.preview-loading {
    color: #ffffff;
    font-size: 26rpx;
}

.preview-actions {
    display: flex;
    justify-content: space-around;
    padding: 16rpx 0;
    background: #fafafa;
    border-top: 1rpx solid #f0f0f0;
}

.preview-btn {
    font-size: 26rpx;
    color: #07c160;
    padding: 8rpx 24rpx;
}

.preview-btn:active {
    opacity: 0.7;
}

.preview-btn.delete {
    color: #fa5151;
}

/* 按钮区 */
.btn-container {
    display: flex;
    gap: 20rpx;
    margin-top: 40rpx;
    padding: 0 8rpx;
}

.reset-btn {
    flex: 1;
    height: 92rpx;
    font-size: 32rpx;
    border-radius: 16rpx;
    background: #ffffff;
    color: #1a1a1a;
    border: 1rpx solid #e5e5e5;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0;
    line-height: 1;
}

.reset-btn::after {
    border: none;
}

.reset-btn:active {
    background: #f7f7f7;
}

.submit-btn {
    flex: 1.5;
    height: 92rpx;
    font-size: 34rpx;
    font-weight: 500;
    border-radius: 16rpx;
    background: #07c160;
    color: #ffffff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0;
    line-height: 1;
    transition: opacity 0.2s ease;
}

.submit-btn::after {
    border: none;
}

.submit-btn:active {
    opacity: 0.85;
}
