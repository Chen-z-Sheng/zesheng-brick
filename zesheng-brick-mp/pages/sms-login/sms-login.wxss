/* pages/sms-login/sms-login.wxss - 验证码登录页，遵循微信 UI 规范 */
.page {
    min-height: 100vh;
    background: #ffffff;
    padding: 80rpx 48rpx 48rpx;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
}

/* 顶部提示 */
.header {
    margin-bottom: 72rpx;
}

.title {
    font-size: 44rpx;
    font-weight: 700;
    color: #1a1a1a;
    display: block;
    margin-bottom: 16rpx;
}

.subtitle {
    font-size: 28rpx;
    color: #999999;
    display: block;
    line-height: 1.6;
}

/* 表单区 */
.form-area {
    flex: 1;
}

.field {
    margin-bottom: 36rpx;
}

.label {
    font-size: 28rpx;
    color: #1a1a1a;
    font-weight: 500;
    margin-bottom: 12rpx;
    display: block;
}

/* 手机号输入框 */
.input-wrap {
    height: 96rpx;
    border-bottom: 2rpx solid #e5e5e5;
    display: flex;
    align-items: center;
    transition: border-color 0.2s ease;
}

.input-wrap-focus {
    border-bottom-color: #07c160;
}

.input {
    flex: 1;
    height: 96rpx;
    font-size: 34rpx;
    color: #1a1a1a;
}

.input-placeholder {
    color: #c8c8c8;
    font-size: 34rpx;
}

/* 验证码行 */
.code-row {
    display: flex;
    align-items: center;
    gap: 20rpx;
}

.code-input-wrap {
    flex: 1;
    height: 96rpx;
    border-bottom: 2rpx solid #e5e5e5;
    display: flex;
    align-items: center;
    transition: border-color 0.2s ease;
}

.code-input-wrap-focus {
    border-bottom-color: #07c160;
}

.code-input {
    flex: 1;
    height: 96rpx;
    font-size: 34rpx;
    color: #1a1a1a;
}

.code-input-placeholder {
    color: #c8c8c8;
    font-size: 34rpx;
}

/* 发送验证码按钮 */
.send-btn {
    min-width: 220rpx;
    height: 72rpx;
    padding: 0 24rpx;
    font-size: 28rpx;
    color: #07c160;
    background: rgba(7, 193, 96, 0.08);
    border: none;
    border-radius: 36rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    line-height: 1;
    flex-shrink: 0;
    transition: all 0.2s ease;
}

.send-btn::after {
    border: none;
}

.send-btn:active {
    background: rgba(7, 193, 96, 0.15);
}

.send-btn[disabled] {
    color: #c8c8c8;
    background: #f7f7f7;
}

/* 登录按钮 */
.login-btn {
    width: 100%;
    height: 96rpx;
    margin-top: 60rpx;
    font-size: 34rpx;
    font-weight: 500;
    border-radius: 16rpx;
    background: #07c160;
    color: #ffffff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0;
    line-height: 1;
    transition: opacity 0.2s ease;
}

.login-btn::after {
    border: none;
}

.login-btn:active {
    opacity: 0.85;
}

.login-btn[disabled] {
    background: #cccccc;
    opacity: 1;
}

/* 底部提示 */
.tip {
    margin-top: 32rpx;
    text-align: center;
    font-size: 24rpx;
    color: #c8c8c8;
    line-height: 1.6;
}
