<view class="page">
    <view class="header">
        <text class="title">登录</text>
        <text class="subtitle">验证码将发送至你的手机号\n请注意查收短信验证码</text>
    </view>

    <view class="form-area">
        <!-- 手机号 -->
        <view class="field">
            <text class="label">手机号</text>
            <view class="input-wrap {{phoneFocus ? 'input-wrap-focus' : ''}}">
                <input
                    class="input"
                    type="number"
                    maxlength="11"
                    placeholder="请输入手机号"
                    placeholder-class="input-placeholder"
                    value="{{phone}}"
                    bindinput="onPhoneInput"
                    bindfocus="onPhoneFocus"
                    bindblur="onPhoneBlur"
                />
            </view>
        </view>

        <!-- 验证码 -->
        <view class="field">
            <text class="label">验证码</text>
            <view class="code-row">
                <view class="code-input-wrap {{codeFocus ? 'code-input-wrap-focus' : ''}}">
                    <input
                        class="code-input"
                        type="number"
                        maxlength="6"
                        placeholder="请输入验证码"
                        placeholder-class="code-input-placeholder"
                        value="{{verifyCode}}"
                        bindinput="onCodeInput"
                        bindfocus="onCodeFocus"
                        bindblur="onCodeBlur"
                    />
                </view>
                <button class="send-btn" bindtap="onSendCode" disabled="{{sending || sendDisabled}}">
                    {{sendBtnText}}
                </button>
            </view>
        </view>

        <!-- 登录按钮 -->
        <button class="login-btn" bindtap="onLogin" disabled="{{loading}}">
            {{loading ? '登录中…' : '登录'}}
        </button>
    </view>

    <view class="tip">如未收到验证码，请检查短信拦截记录</view>
</view>
