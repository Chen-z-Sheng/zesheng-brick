<scroll-view class="page" scroll-y show-scrollbar="{{false}}">
    <view class="doc-header">
        <text class="doc-title">{{title}}</text>
        <text class="doc-update">更新日期：{{updateTime}}</text>
    </view>

    <view class="section" wx:for="{{sections}}" wx:key="heading">
        <text class="section-heading">{{item.heading}}</text>
        <text class="section-paragraph" wx:for="{{item.paragraphs}}" wx:for-item="para" wx:key="*this">{{para}}</text>
    </view>
</scroll-view>
