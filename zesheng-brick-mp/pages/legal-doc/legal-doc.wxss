.page {
    height: 100vh;
    box-sizing: border-box;
    padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
    background: #f7f7f7;
}

.doc-header {
    margin-bottom: 28rpx;
    padding: 28rpx;
    background: #ffffff;
    border-radius: 16rpx;
}

.doc-title {
    display: block;
    font-size: 36rpx;
    font-weight: 600;
    color: #111827;
    line-height: 1.4;
}

.doc-update {
    display: block;
    margin-top: 12rpx;
    font-size: 24rpx;
    color: #6b7280;
}

.section {
    margin-bottom: 20rpx;
    padding: 28rpx;
    background: #ffffff;
    border-radius: 16rpx;
}

.section-heading {
    display: block;
    font-size: 30rpx;
    font-weight: 600;
    color: #111827;
    line-height: 1.4;
    margin-bottom: 16rpx;
}

.section-paragraph {
    display: block;
    font-size: 28rpx;
    color: #374151;
    line-height: 1.65;
    margin-bottom: 12rpx;
}

.section-paragraph:last-child {
    margin-bottom: 0;
}
