/* pages/feedback-history/feedback-history.wxss - 反馈历史页，遵循微信 UI 规范 */
.page {
    min-height: 100vh;
    background: #f7f7f7;
    padding: 24rpx;
    padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
    box-sizing: border-box;
}

/* 页面标题 */
.page-header {
    padding: 8rpx 8rpx 20rpx;
}

.page-title {
    font-size: 36rpx;
    font-weight: 700;
    color: #1a1a1a;
    display: block;
}

/* 加载状态 */
.loading {
    padding: 120rpx 0;
    text-align: center;
    color: #b0b0b0;
    font-size: 28rpx;
}

/* 空状态 */
.empty {
    padding: 120rpx 0;
    text-align: center;
    color: #b0b0b0;
    font-size: 28rpx;
}

.empty-icon {
    font-size: 80rpx;
    display: block;
    margin-bottom: 16rpx;
}

/* 反馈卡片 */
.feedback-card {
    background: #ffffff;
    border-radius: 24rpx;
    padding: 28rpx 32rpx;
    margin-bottom: 20rpx;
    transition: background-color 0.15s ease;
}

.feedback-card:active {
    background: #f9f9f9;
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16rpx;
}

.type-tag {
    display: inline-block;
    font-size: 24rpx;
    color: #07c160;
    background: rgba(7, 193, 96, 0.08);
    padding: 6rpx 20rpx;
    border-radius: 20rpx;
    font-weight: 500;
}

.time {
    font-size: 24rpx;
    color: #b0b0b0;
    flex-shrink: 0;
}

.content {
    font-size: 30rpx;
    color: #1a1a1a;
    line-height: 1.6;
    display: block;
    word-break: break-all;
}

/* 回复区域 */
.reply-box {
    margin-top: 20rpx;
    background: #f7f7f7;
    border-radius: 16rpx;
    padding: 20rpx 24rpx;
    border-left: 6rpx solid #07c160;
}

.reply-title {
    display: block;
    color: #666666;
    font-size: 24rpx;
    margin-bottom: 8rpx;
    font-weight: 500;
}

.reply-content {
    color: #1a1a1a;
    font-size: 28rpx;
    line-height: 1.6;
    display: block;
}

.reply-empty {
    color: #b0b0b0;
    font-size: 26rpx;
}
