/* pages/customer-service/customer-service.wxss - 客服页面样式 */
page {
    height: 100vh;
    background: var(--bg-primary);
    overflow: hidden;
}

.page-root {
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: var(--bg-primary);
}

.chat-wrapper {
    width: 100%;
    height: 100%;
    overflow: hidden;
}

.chat-panel {
    width: 100%;
    height: 100%;
}

/* ============================================
   状态盒子样式
   ============================================ */
.state-box {
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16rpx;
    padding: 48rpx;
    box-sizing: border-box;
}

.state-title {
    font-size: 32rpx;
    color: var(--text-primary);
    font-weight: 600;
    text-align: center;
}

.state-title--error {
    color: var(--danger-color);
}

.state-desc {
    font-size: 26rpx;
    color: var(--text-secondary);
    text-align: center;
    line-height: 1.5;
    max-width: 500rpx;
}

.retry-btn {
    margin-top: 16rpx;
    width: 280rpx;
    height: 80rpx;
    line-height: 80rpx;
    border-radius: var(--radius-full);
    font-size: 30rpx;
    font-weight: 600;
    color: #ffffff;
    background: var(--primary-gradient);
    border: none;
    box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.25);
}

.retry-btn::after {
    border: none;
}

.retry-btn:active {
    transform: translateY(2rpx);
    box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.2);
}
