/* pages/about/about.wxss - 关于页面，遵循微信 UI 规范 */
.page {
    background: #f7f7f7;
    padding: 24rpx;
    padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
    min-height: 100vh;
    box-sizing: border-box;
}

/* 顶部品牌区 */
.brand-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 48rpx 32rpx 40rpx;
    background: #ffffff;
    border-radius: 24rpx;
    margin-bottom: 24rpx;
}

.app-logo {
    width: 128rpx;
    height: 128rpx;
    border-radius: 32rpx;
    margin-bottom: 20rpx;
    background: linear-gradient(135deg, #07c160, #06ad56);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 64rpx;
    color: #ffffff;
    box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.25);
}

.app-name {
    font-size: 38rpx;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 8rpx;
}

.app-version {
    font-size: 26rpx;
    color: #b0b0b0;
}

/* 内容卡片 */
.content-card {
    background: #ffffff;
    border-radius: 24rpx;
    padding: 8rpx 32rpx;
    margin-bottom: 24rpx;
}

/* 列表项 */
.cell-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 104rpx;
    padding: 0 4rpx;
    border-bottom: 1rpx solid #f5f5f5;
    transition: background-color 0.15s ease;
}

.cell-item:last-child {
    border-bottom: none;
}

.cell-item:active {
    background: #f9f9f9;
    margin: 0 -32rpx;
    padding: 0 36rpx;
    border-radius: 0;
}

.cell-left {
    display: flex;
    align-items: center;
    gap: 20rpx;
}

.cell-icon {
    font-size: 36rpx;
    line-height: 1;
}

.cell-label {
    font-size: 32rpx;
    color: #1a1a1a;
}

.cell-value {
    font-size: 28rpx;
    color: #b0b0b0;
    flex-shrink: 0;
}

.cell-arrow {
    font-size: 24rpx;
    color: #c0c0c0;
    margin-left: 8rpx;
    flex-shrink: 0;
}

/* 功能说明卡片 */
.intro-card {
    background: #ffffff;
    border-radius: 24rpx;
    padding: 28rpx 32rpx;
    margin-bottom: 24rpx;
}

.intro-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 20rpx;
    display: block;
}

.intro-text {
    display: block;
    font-size: 28rpx;
    color: #666666;
    line-height: 1.8;
}

.intro-list {
    margin-top: 20rpx;
}

.intro-item {
    border-bottom: none;
    min-height: 0;
    padding: 12rpx 0;
}

.intro-item-text {
    font-size: 28rpx;
    color: #666666;
}

/* 联系方式卡片 */
.contact-card {
    background: #ffffff;
    border-radius: 24rpx;
    padding: 28rpx 32rpx;
    margin-bottom: 24rpx;
    text-align: center;
}

.contact-title {
    font-size: 28rpx;
    color: #999999;
    margin-bottom: 16rpx;
    display: block;
}

.contact-id {
    display: inline-flex;
    align-items: center;
    gap: 12rpx;
    font-size: 32rpx;
    font-weight: 600;
    color: #07c160;
    background: rgba(7, 193, 96, 0.08);
    padding: 12rpx 32rpx;
    border-radius: 40rpx;
}

.copy-text {
    font-size: 24rpx;
    color: #999999;
}

/* 底部版权 */
.footer {
    text-align: center;
    padding: 24rpx 0 0;
}

.footer-text {
    font-size: 22rpx;
    color: #c8c8c8;
    display: block;
    line-height: 1.8;
}
