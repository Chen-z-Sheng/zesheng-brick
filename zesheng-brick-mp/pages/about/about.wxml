<view class="page">
    <!-- 品牌展示区 -->
    <view class="brand-section">
        <view class="app-logo">🧱</view>
        <text class="app-name">泽晟搬砖助手</text>
        <text class="app-version">v1.0.0</text>
    </view>

    <!-- 功能说明 -->
    <view class="intro-card">
        <text class="intro-title">功能说明</text>
        <text class="intro-text">泽晟搬砖助手是一款面向撸货、行情报单场景的实用工具，致力于帮助用户更高效地完成日常操作。\n\n目前支持以下核心功能：</text>
        <view class="intro-list">
            <view class="cell-item intro-item">
                <text class="cell-label intro-item-text">📊 行情 — 实时查看商品行情价格</text>
            </view>
            <view class="cell-item intro-item">
                <text class="cell-label intro-item-text">📋 报单 — 快速提交固结方案报单</text>
            </view>
            <view class="cell-item intro-item">
                <text class="cell-label intro-item-text">💰 打款信息 — 管理收款账号与二维码</text>
            </view>
            <view class="cell-item intro-item">
                <text class="cell-label intro-item-text">📞 客服 — 人工客服与智能助手随时响应</text>
            </view>
        </view>
    </view>

    <!-- 联系方式 -->
    <view class="contact-card">
        <text class="contact-title">如需帮助，请添加客服微信</text>
        <view class="contact-id" bindtap="onCopyContact">
            <text>czk666888fff</text>
            <text class="copy-text">复制</text>
        </view>
    </view>

    <!-- 其他信息 -->
    <view class="content-card">
        <view class="cell-item" bindtap="onGoHelp">
            <view class="cell-left">
                <text class="cell-icon">❓</text>
                <text class="cell-label">帮助中心</text>
            </view>
            <text class="cell-arrow">›</text>
        </view>
        <view class="cell-item" bindtap="onCheckUpdate">
            <view class="cell-left">
                <text class="cell-icon">🔄</text>
                <text class="cell-label">检查更新</text>
            </view>
            <view class="cell-right">
                <text class="cell-value">当前已是最新版本</text>
                <text class="cell-arrow">›</text>
            </view>
        </view>
    </view>

    <!-- 底部版权 -->
    <view class="footer">
        <text class="footer-text">泽晟搬砖助手 © 2024</text>
        <text class="footer-text">用心服务每一位用户</text>
    </view>
</view>
