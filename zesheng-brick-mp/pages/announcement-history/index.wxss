/* pages/announcement-history/index.wxss - 公告历史页，遵循微信 UI 规范 */
.page-container {
    min-height: 100vh;
    background: #f7f7f7;
    padding: 24rpx;
    padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
    box-sizing: border-box;
}

/* 页面标题 */
.page-header {
    padding: 8rpx 8rpx 20rpx;
}

.page-title {
    font-size: 36rpx;
    font-weight: 700;
    color: #1a1a1a;
    display: block;
}

/* 加载/空状态 */
.loading-wrap,
.empty-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    color: #b0b0b0;
}

.loading-text,
.empty-title {
    font-size: 30rpx;
    font-weight: 500;
    color: #999999;
}

.empty-desc {
    margin-top: 12rpx;
    font-size: 26rpx;
    color: #c8c8c8;
}

/* 公告列表 */
.announcement-list {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
}

.announcement-card {
    background: #ffffff;
    border-radius: 24rpx;
    padding: 28rpx 32rpx;
    transition: background-color 0.15s ease;
}

.announcement-card:active {
    background: #f9f9f9;
}

.announcement-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16rpx;
}

.announcement-title {
    flex: 1;
    font-size: 32rpx;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1.5;
}

.announcement-status {
    flex-shrink: 0;
    padding: 6rpx 16rpx;
    border-radius: 20rpx;
    background: rgba(7, 193, 96, 0.1);
    color: #07c160;
    font-size: 22rpx;
    line-height: 1.4;
    font-weight: 500;
}

.announcement-time {
    display: block;
    margin-top: 12rpx;
    font-size: 24rpx;
    color: #b0b0b0;
}

.announcement-preview {
    display: block;
    margin-top: 16rpx;
    font-size: 28rpx;
    line-height: 1.6;
    color: #666666;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}

/* 详情弹窗 */
.detail-mask {
    position: fixed;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.detail-dialog {
    width: 85%;
    max-height: 78vh;
    background: #ffffff;
    border-radius: 28rpx;
    padding: 36rpx 32rpx;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    position: relative;
    animation: scaleIn 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes scaleIn {
    from { transform: scale(0.9); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
}

.detail-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16rpx;
}

.detail-title {
    flex: 1;
    font-size: 36rpx;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.5;
}

.detail-time {
    display: block;
    margin-top: 16rpx;
    font-size: 24rpx;
    color: #b0b0b0;
}

.detail-body {
    margin-top: 24rpx;
    max-height: 50vh;
    padding-right: 8rpx;
}

.detail-content-wrap {
    padding-bottom: 20rpx;
}

.detail-content {
    display: block;
    font-size: 30rpx;
    line-height: 1.8;
    color: #333333;
    word-break: break-all;
}

.detail-button {
    margin-top: 28rpx;
    height: 88rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 16rpx;
    padding: 0;
    background: #07c160;
    color: #ffffff;
    font-size: 32rpx;
    font-weight: 500;
    border: none;
    transition: opacity 0.2s ease;
}

.detail-button::after {
    border: none;
}

.detail-button:active {
    opacity: 0.85;
}
