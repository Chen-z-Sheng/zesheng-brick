/* pages/help-center/help-center.wxss - 帮助中心，遵循微信 UI 规范 */
.page {
    background: #f7f7f7;
    padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
    min-height: 100vh;
    box-sizing: border-box;
}

/* 搜索框 */
.search-section {
    padding: 24rpx 24rpx 16rpx;
    position: sticky;
    top: 0;
    background: #f7f7f7;
    z-index: 10;
}

.search-box {
    display: flex;
    align-items: center;
    height: 76rpx;
    padding: 0 24rpx;
    background: #ffffff;
    border-radius: 16rpx;
    border: 1rpx solid #f0f0f0;
}

.search-icon {
    font-size: 32rpx;
    margin-right: 14rpx;
    color: #b0b0b0;
    flex-shrink: 0;
}

.search-input {
    flex: 1;
    font-size: 30rpx;
    color: #1a1a1a;
    height: 76rpx;
}

.search-placeholder {
    color: #b0b0b0;
    font-size: 30rpx;
}

/* 常见问题 */
.faq-section {
    padding: 8rpx 24rpx 24rpx;
}

.section-title {
    font-size: 30rpx;
    font-weight: 600;
    color: #1a1a1a;
    padding: 16rpx 8rpx;
    display: block;
}

.faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
}

.faq-item {
    background: #ffffff;
    border-radius: 0;
    overflow: hidden;
    transition: background-color 0.15s ease;
}

.faq-item:first-child {
    border-radius: 24rpx 24rpx 0 0;
}

.faq-item:last-child {
    border-radius: 0 0 24rpx 24rpx;
}

.faq-item:first-child:last-child {
    border-radius: 24rpx;
}

.faq-item:active {
    background: #f9f9f9;
}

.faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 30rpx 28rpx;
    min-height: 48rpx;
}

.faq-q {
    flex: 1;
    font-size: 30rpx;
    color: #1a1a1a;
    line-height: 1.5;
    padding-right: 20rpx;
    font-weight: 400;
}

.faq-arrow {
    font-size: 22rpx;
    color: #b0b0b0;
    flex-shrink: 0;
    transition: transform 0.2s ease;
}

.faq-item.expanded .faq-arrow {
    color: #07c160;
}

.faq-answer {
    padding: 0 28rpx 28rpx;
    border-top: 1rpx solid #f5f5f5;
    animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(-8rpx); }
    to { opacity: 1; transform: translateY(0); }
}

.faq-a {
    display: block;
    font-size: 28rpx;
    color: #666666;
    line-height: 1.7;
    padding-top: 20rpx;
}

.faq-loading {
    padding: 80rpx 40rpx;
    text-align: center;
    font-size: 28rpx;
    color: #b0b0b0;
}

.empty-tip {
    padding: 80rpx 40rpx;
    text-align: center;
    font-size: 28rpx;
    color: #b0b0b0;
}

/* 底部客服区域 */
.contact-section {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 24rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
    background: #ffffff;
    box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.contact-title {
    font-size: 26rpx;
    color: #999999;
    text-align: center;
    margin-bottom: 20rpx;
}

.contact-buttons {
    display: flex;
    gap: 20rpx;
}

.contact-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 88rpx;
    border-radius: 16rpx;
    margin: 0;
    padding: 0 16rpx;
    line-height: normal;
    border: none;
    box-sizing: border-box;
    transition: opacity 0.2s ease;
}

.contact-btn-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12rpx;
    width: 100%;
}

.contact-btn-hover-human {
    opacity: 0.88;
}

.contact-btn-hover-ai {
    opacity: 0.92;
}

.contact-btn::after {
    border: none;
}

.contact-btn:active {
    opacity: 0.85;
}

.contact-btn.human {
    background: #07c160;
    color: #ffffff;
}

.contact-btn.human .btn-text,
.contact-btn.human .btn-icon {
    color: #ffffff;
}

.contact-btn.ai {
    background: #ffffff;
    color: #1a1a1a;
    border: 1rpx solid #e5e5e5;
}

.contact-btn.ai .btn-text {
    color: #1a1a1a;
}

.btn-icon {
    font-size: 32rpx;
    line-height: 1.2;
    flex-shrink: 0;
}

.btn-text {
    font-size: 28rpx;
    font-weight: 500;
    line-height: 1.3;
    flex-shrink: 0;
}
