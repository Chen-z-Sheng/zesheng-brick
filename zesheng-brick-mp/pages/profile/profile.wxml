<!--pages/profile/profile.wxml - 个人信息页-->
<view class="container" style="padding-top: {{statusBarHeight}}px;">
    <navigation-bar title="个人信息" background="#ffffff" color="#111827" back="{{true}}" />

    <!-- 信息表单 -->
    <view class="form-card">
        <!-- 昵称 -->
        <view class="form-item">
            <text class="form-label">昵称</text>
            <input
                class="form-input"
                type="nickname"
                placeholder="请输入昵称"
                placeholder-class="form-input-placeholder"
                value="{{tempNickName}}"
                bindinput="onNickNameInput"
                bindblur="onNickNameBlur"
            />
            <view class="wechat-name-btn" bindtap="onUseWechatName" wx:if="{{!tempNickName}}">
                使用微信名
            </view>
            <view class="form-arrow" wx:else>✕</view>
        </view>

        <!-- 手机号 -->
        <view class="form-item">
            <text class="form-label">手机号</text>
            <input
                class="form-input"
                type="number"
                placeholder="请输入手机号"
                placeholder-class="form-input-placeholder"
                value="{{tempPhone || userInfo.phone}}"
                bindinput="onPhoneInput"
                maxlength="11"
            />
        </view>
    </view>

    <!-- 保存按钮 -->
    <view class="save-section" wx:if="{{isEditing}}">
        <button class="save-btn" bindtap="saveUserInfo">保存修改</button>
    </view>

    <!-- 提示语 -->
    <view class="tips-section" wx:if="{{!isEditing}}">
        <text class="tips-text">修改昵称或手机号后点击保存即可更新</text>
    </view>
</view>
