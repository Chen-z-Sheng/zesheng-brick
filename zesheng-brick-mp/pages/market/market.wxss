/* pages/market/market.wxss */
page {
    height: 100%;
    overflow: hidden;
    background: #f7f7f7;
}

.market-page {
    height: 100vh;
    background: #f7f7f7;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-sizing: border-box;
}

/* ============================================
   搜索框 - 贴顶设计
   ============================================ */
.search-bar {
    display: flex;
    align-items: center;
    background: #ffffff;
    padding: 16rpx 24rpx;
    flex-shrink: 0;
    border-bottom: 1rpx solid #f0f0f0;
    gap: 16rpx;
}

.search-inner {
    flex: 1;
    display: flex;
    align-items: center;
    background: #f5f5f5;
    border-radius: 8rpx;
    padding: 0 20rpx;
    height: 68rpx;
    gap: 12rpx;
}

.search-icon-txt {
    font-size: 28rpx;
    color: #999999;
    flex-shrink: 0;
}

.search-input {
    flex: 1;
    height: 68rpx;
    font-size: 28rpx;
    color: #1a1a1a;
    background: transparent;
    border: none;
}

.clear-btn {
    font-size: 26rpx;
    color: #07c160;
    flex-shrink: 0;
    padding: 8rpx 0;
}

/* ============================================
   一级分类标签栏 - 微信风格横向滚动
   ============================================ */
.category-scroll {
    background: #ffffff;
    border-bottom: 1rpx solid #f0f0f0;
    flex-shrink: 0;
}

.category-scroll-inner {
    display: inline-flex;
    align-items: center;
    padding: 12rpx 24rpx 16rpx;
    gap: 12rpx;
    white-space: nowrap;
}

.category-item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 60rpx;
    padding: 0 28rpx;
    border-radius: 30rpx;
    background: #f5f5f5;
    color: #666666;
    font-size: 28rpx;
    font-weight: 400;
    transition: all 0.2s;
    flex-shrink: 0;
}

.category-item--active {
    background: #07c160;
    color: #ffffff;
    font-weight: 600;
}

/* ============================================
   状态提示
   ============================================ */
.state-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    flex: 1;
}

.state-wrapper--outer {
    margin: 24rpx;
    background: #ffffff;
    border-radius: 16rpx;
    padding: 80rpx 0;
    flex: 1;
}

.state-wrapper--inner {
    padding: 80rpx 0;
    flex: 1;
}

.state-text {
    font-size: 28rpx;
    color: #999999;
}

.state-text--error {
    color: #ef4444;
}

/* ============================================
   分类面板 - 修复右边框被截断问题
   ============================================ */
.category-panel {
    flex: 1;
    min-height: 0;
    display: flex;
    margin: 0;
    /* 关键：不能用 overflow:hidden，否则右侧 scroll-view 内的边框会被截掉 */
    /* 用背景色分隔，不用 overflow */
    background: #ffffff;
}

/* 左侧二级分类导航 */
.level2-column {
    width: 192rpx;
    height: 100%;
    background: #f7f7f7;
    flex-shrink: 0;
    /* 左列独立滚动 */
}

.level2-inner {
    padding: 16rpx 0;
}

.level2-item {
    min-height: 88rpx;
    padding: 16rpx 16rpx;
    box-sizing: border-box;
    font-size: 28rpx;
    color: #666666;
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    white-space: normal;
    word-break: break-all;
    line-height: 1.4;
    position: relative;
    transition: all 0.2s;
}

.level2-item--active {
    background: #ffffff;
    color: #07c160;
    font-weight: 600;
}

/* 激活状态左侧竖线指示 */
.level2-item--active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 6rpx;
    height: 40rpx;
    background: #07c160;
    border-radius: 0 3rpx 3rpx 0;
}

/* 右侧三级商品区域 */
.level3-container {
    flex: 1;
    height: 100%;
    background: #ffffff;
    /* 左侧竖向分隔线 */
    border-left: 1rpx solid #f0f0f0;
    min-width: 0;
}

.level3-column {
    height: 100%;
}

.level3-content {
    padding: 16rpx 16rpx 40rpx;
    box-sizing: border-box;
    min-height: 100%;
}

/* ============================================
   商品卡片 - 简洁风格
   ============================================ */
.product-card {
    background: #ffffff;
    border-radius: 12rpx;
    padding: 20rpx 20rpx;
    border: 1rpx solid #f0f0f0;
    margin-bottom: 12rpx;
    transition: all 0.2s;
}

.product-card:active {
    background: #f7f7f7;
}

.product-card:last-child {
    margin-bottom: 0;
}

.product-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12rpx;
    margin-bottom: 14rpx;
}

.product-name {
    flex: 1;
    font-size: 28rpx;
    color: #1a1a1a;
    font-weight: 500;
    line-height: 1.4;
    word-break: break-all;
}

.product-date {
    font-size: 24rpx;
    color: #bbbbbb;
    flex-shrink: 0;
    margin-top: 4rpx;
    white-space: nowrap;
}

.product-price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.price-label {
    font-size: 24rpx;
    color: #999999;
}

.price-value {
    font-size: 34rpx;
    color: #ef4444;
    font-weight: 700;
}

/* ============================================
   历史行情弹出面板 - bottom sheet
   ============================================ */
.history-mask {
    position: fixed;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: flex-end;
    z-index: 999;
    animation: maskFadeIn 0.25s ease;
}

@keyframes maskFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.history-panel {
    width: 100%;
    background: #ffffff;
    border-top-left-radius: 24rpx;
    border-top-right-radius: 24rpx;
    padding: 0 0 16rpx;
    box-sizing: border-box;
    animation: panelSlideUp 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

@keyframes panelSlideUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
}

/* 顶部拖拽指示条 */
.history-drag-bar {
    display: flex;
    justify-content: center;
    padding: 20rpx 0 8rpx;
}

.history-drag-indicator {
    width: 72rpx;
    height: 8rpx;
    background: #e0e0e0;
    border-radius: 4rpx;
}

.history-head {
    padding: 16rpx 32rpx 24rpx;
    border-bottom: 1rpx solid #f0f0f0;
}

.history-name-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8rpx;
}

.history-head-actions {
    display: flex;
    align-items: center;
    gap: 12rpx;
}

.history-title {
    font-size: 34rpx;
    font-weight: 600;
    color: #1a1a1a;
}

.history-price-badge {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    font-size: 28rpx;
    font-weight: 700;
    padding: 8rpx 20rpx;
    border-radius: 8rpx;
}

.history-subtitle {
    font-size: 24rpx;
    color: #999999;
}

.history-tip {
    margin-top: 8rpx;
    display: block;
    font-size: 24rpx;
    color: #b0b0b0;
}

.history-body {
    padding: 12rpx 28rpx;
}

.history-chart {
    width: 100%;
    height: 320rpx;
    background: #fafafa;
    border-radius: 12rpx;
}

.history-empty {
    padding: 24rpx 0;
    color: #999999;
    font-size: 28rpx;
    text-align: center;
}


