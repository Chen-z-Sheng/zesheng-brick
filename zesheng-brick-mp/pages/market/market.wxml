<view class="market-page">
    <!-- 搜索框 -->
    <view class="search-bar">
        <view class="search-inner">
            <text class="search-icon-txt">🔍</text>
            <input
                class="search-input"
                placeholder="搜索商品名称"
                placeholder-style="color:#bbbbbb"
                value="{{displayKeyword}}"
                bindinput="onKeywordInput"
                confirm-type="search"
            />
            <text class="clear-btn" wx:if="{{displayKeyword}}" bindtap="onClearKeyword">清空</text>
        </view>
    </view>

    <!-- 一级分类横向滚动 -->
    <scroll-view class="category-scroll" scroll-x enable-flex show-scrollbar="{{false}}">
        <view class="category-scroll-inner">
            <view
                class="category-item {{activeLevel1Id == item.id ? 'category-item--active' : ''}}"
                wx:for="{{level1Categories}}"
                wx:key="id"
                data-id="{{item.id}}"
                bindtap="onLevel1Tap"
            >{{item.name}}</view>
        </view>
    </scroll-view>

    <!-- 加载中 -->
    <view class="state-wrapper state-wrapper--outer" wx:if="{{loading}}">
        <text class="state-text">行情加载中...</text>
    </view>

    <!-- 加载出错 -->
    <view class="state-wrapper state-wrapper--outer" wx:elif="{{errorMessage}}">
        <text class="state-text state-text--error">{{errorMessage}}</text>
    </view>

    <!-- 二级+三级联动面板 -->
    <view class="category-panel" wx:elif="{{!errorMessage}}">
        <!-- 左侧二级分类 -->
        <scroll-view class="level2-column" scroll-y show-scrollbar="{{false}}">
            <view class="level2-inner">
                <view
                    class="level2-item {{activeLevel2Id == item.id ? 'level2-item--active' : ''}}"
                    wx:for="{{level2Categories}}"
                    wx:key="id"
                    data-id="{{item.id}}"
                    bindtap="onLevel2Tap"
                >{{item.name}}</view>
            </view>
        </scroll-view>

        <!-- 右侧三级商品列表 -->
        <view class="level3-container">
            <scroll-view class="level3-column" scroll-y="{{level3CanScroll}}" show-scrollbar="{{false}}">
                <view class="level3-content">
                    <view class="state-wrapper state-wrapper--inner" wx:if="{{loading}}">
                        <text class="state-text">加载中...</text>
                    </view>
                    <view class="state-wrapper state-wrapper--inner" wx:elif="{{!filteredThirdProducts.length}}">
                        <text class="state-text">暂无商品行情</text>
                    </view>
                    <block wx:else>
                        <view
                            class="product-card"
                            wx:for="{{filteredThirdProducts}}"
                            wx:key="id"
                            data-item="{{item}}"
                            bindtap="onProductTap"
                        >
                            <view class="product-header">
                                <text class="product-name">{{item.productName}}</text>
                                <text class="product-date">{{item.latestDate || ''}}</text>
                            </view>
                            <view class="product-price-row">
                                <text class="price-label">回收行情</text>
                                <text class="price-value">￥{{item.displayPrice}}</text>
                            </view>
                        </view>
                    </block>
                </view>
            </scroll-view>
        </view>
    </view>

    <!-- 历史行情弹出面板 -->
    <view class="history-mask" wx:if="{{historyVisible}}" catchtouchmove="true" bindtap="onCloseHistory">
        <view class="history-panel" catchtap="true">
            <!-- 顶部拖拽条 -->
            <view class="history-drag-bar">
                <view class="history-drag-indicator"></view>
            </view>
            <!-- 标题区域 -->
            <view class="history-head">
                <view class="history-name-row">
                    <text class="history-title">{{selectedProductName}}</text>
                    <view class="history-head-actions">
                        <text class="history-price-badge">￥{{selectedProductPrice}}</text>
                        <view class="history-head-close" bindtap="onCloseHistory">×</view>
                    </view>
                </view>
                <text class="history-subtitle">{{selectedProductDate}} 更新</text>
                <text class="history-tip">滑动可查看历史趋势，价格仅供参考</text>
            </view>
            <!-- 图表区域 -->
            <view class="history-body" wx:if="{{historyList.length}}">
                <canvas type="2d" id="historyChart" class="history-chart"></canvas>
            </view>
            <view class="history-empty" wx:else>暂无历史行情数据</view>
            <!-- 底部关闭 -->
            <view class="history-footer">
                <view class="history-close-btn" bindtap="onCloseHistory">关闭</view>
            </view>
        </view>
    </view>
</view>
