# ========== Monorepo 根目录统一忽略（仅此处维护，子目录勿再放 .gitignore） ==========

# ---------- 密钥 / 本机环境（勿提交） ----------
scripts/zesheng-server-env.sh
zesheng-brick-parent/zesheng-admin-service/src/main/resources/application-dev.yml
zesheng-brick-parent/zesheng-client-service/src/main/resources/application-dev.yml
zesheng-brick-parent/docker/.env.docker.prod

# ---------- Docker：保留 Dockerfile / compose / 脚本 / 示例配置，仅忽略构建产物 ----------
zesheng-brick-parent/docker/out/*.tar
zesheng-brick-parent/docker/admin/*.jar
zesheng-brick-parent/docker/client/*.jar

# ---------- Java / Maven ----------
**/target/
**/.mvn/timing.properties
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
*.class
*.jar
*.war
*.ear
*.log
logs/
temp/
tmp/

# ---------- Gradle（parent 模块若使用） ----------
zesheng-brick-parent/build/
zesheng-brick-parent/.nb-gradle/

# ---------- 管理后台前端 zesheng-brick-admin-web ----------
